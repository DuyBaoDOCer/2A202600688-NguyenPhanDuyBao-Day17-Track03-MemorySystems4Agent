# Copy this file to .env and fill in your values.

# ============================================================
# PRIMARY: ai-gateway.antco.ai  (OpenAI-compatible custom gateway)
# ============================================================
LLM_PROVIDER=custom
CUSTOM_API_KEY=<paste-your-key-from-ai-gateway.antco.ai-here>

# Base URL of the API endpoint — find this in the gateway dashboard
# Common patterns (try /v1 first):
CUSTOM_BASE_URL=https://ai-gateway.antco.ai/v1

# Model name — check which models the gateway exposes
LLM_MODEL=mistral-small-latest

# Optional: temperature (default 0.3)
# LLM_TEMPERATURE=0.3

# Optional: compact memory settings
# COMPACT_THRESHOLD=800       # tokens before compaction triggers
# COMPACT_KEEP_MESSAGES=4     # recent messages to keep after compaction

# Optional: confidence threshold for User.md fact writing (BONUS feature)
# 0.6 = default; filters implicit mentions (0.5) but keeps all explicit declarations
# 0.85 = strict; only explicit declarations and documented corrections pass
# 0.0  = no filtering (useful for offline testing)
# CONFIDENCE_THRESHOLD=0.6

# ============================================================
# Other providers (change LLM_PROVIDER to switch)
# ============================================================
# LLM_PROVIDER=mistral
# MISTRAL_API_KEY=your-mistral-key
# LLM_MODEL=mistral-small-latest

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-key
# LLM_MODEL=gemini-1.5-flash

# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key
# LLM_MODEL=gpt-4o-mini

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key
# LLM_MODEL=claude-haiku-4-5-20251001

# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
